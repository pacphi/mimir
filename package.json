{
  "name": "mimir",
  "version": "0.1.0",
  "private": true,
  "description": "Mimir — fleet management control plane for Sindri environments",
  "scripts": {
    "dev": "turbo run dev --parallel",
    "build": "turbo run build",
    "test": "turbo run test",
    "test:coverage": "turbo run test:coverage",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,css,md,yaml,yml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,json,css,md,yaml,yml}\"",
    "typecheck": "turbo run typecheck",
    "db:generate": "turbo run db:generate --filter=@mimir/api",
    "db:migrate": "pnpm --filter=@mimir/api run db:migrate",
    "db:migrate:deploy": "turbo run db:migrate:deploy --filter=@mimir/api",
    "db:seed": "pnpm --filter=@mimir/api run db:seed",
    "db:reset": "pnpm --filter=@mimir/api run db:reset",
    "db:studio": "pnpm --filter=@mimir/api run db:studio",
    "infra:up": "docker compose up -d postgres redis",
    "infra:down": "docker compose down",
    "infra:reset": "docker compose down -v && docker compose up -d postgres redis",
    "infra:logs": "docker compose logs -f",
    "prepare": "husky",
    "deadcode": "knip --no-exit-code"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.0.3",
    "husky": "^9.1.7",
    "knip": "^5.88.0",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "turbo": "^2.8.17",
    "typescript-eslint": "^8.57.1"
  },
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=10.0.0"
  },
  "lint-staged": {
    "*.{ts,tsx,js,json,css,md,yaml,yml}": "prettier --check",
    "apps/**/*.{ts,tsx,js}": "eslint --no-warn-ignored"
  },
  "packageManager": "pnpm@10.30.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/engines",
      "bcrypt",
      "esbuild",
      "node-pty",
      "prisma"
    ],
    "overrides": {
      "lodash@>=4.0.0 <4.17.23": "4.17.23",
      "hono@<4.11.10": "^4.12.2",
      "minimatch@>=10.0.0 <10.2.3": ">=10.2.3",
      "dompurify@>=3.1.3 <=3.3.1": "3.3.2"
    },
    "peerDependencyRules": {
      "allowedVersions": {
        "eslint-plugin-react-hooks>eslint": "10"
      }
    }
  }
}
