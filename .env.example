# Mimir Control Plane — Environment Variables
# Copy to .env and fill in values.

# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_DB=mimir
POSTGRES_USER=mimir
POSTGRES_PASSWORD=changeme
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379

# ── API ───────────────────────────────────────────────────────────────────────
API_PORT=3001
NODE_ENV=development
LOG_LEVEL=debug
CORS_ORIGIN=http://localhost:5173
JWT_SECRET=changeme
SESSION_SECRET=changeme
MIMIR_API_KEY=changeme

# ── Auth (Better Auth) ───────────────────────────────────────────────────
BETTER_AUTH_URL=http://localhost:3001

# GitHub OAuth — create at https://github.com/settings/developers
# Callback URL: http://localhost:3001/api/auth/callback/github
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Google OAuth — create at https://console.cloud.google.com/apis/credentials
# Callback URL: http://localhost:3001/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Magic link email — get API key from https://resend.com
RESEND_API_KEY=
EMAIL_FROM=noreply@sindri.dev

# Dev only — skip auth and auto-login as seed admin user
# AUTH_BYPASS=true

# Optional: Sindri CLI integration (for registry queries)
# Must be an absolute path — relative paths will not resolve correctly
# because the API process cwd varies depending on how it is started.
# SINDRI_BIN_PATH=/usr/local/bin/sindri
# SINDRI_CLI_TIMEOUT_MS=15000

# ── Web ───────────────────────────────────────────────────────────────────────
WEB_PORT=5173

# ── Retention ─────────────────────────────────────────────────────────────────
# METRICS_RETENTION_DAYS=30
# LOGS_RETENTION_DAYS=14
# EVENTS_RETENTION_DAYS=90
# AUDIT_RETENTION_DAYS=365
