{
  "name": "@mimir/api",
  "version": "0.1.0",
  "description": "Mimir Backend API",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch --env-file=../../.env src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "db:generate": "prisma generate",
    "db:migrate": "set -a && . ../../.env && set +a && prisma migrate dev",
    "db:migrate:deploy": "set -a && . ../../.env && set +a && prisma migrate deploy",
    "db:push": "set -a && . ../../.env && set +a && prisma db push",
    "db:reset": "set -a && . ../../.env && set +a && bash scripts/db-reset.sh",
    "db:seed": "set -a && . ../../.env && set +a && prisma db seed",
    "db:studio": "set -a && . ../../.env && set +a && prisma studio",
    "test": "vitest run",
    "test:e2e": "vitest run --include 'tests/*.test.ts'",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src tests",
    "typecheck": "tsc --noEmit",
    "postinstall": "chmod +x ../../node_modules/.pnpm/node-pty@*/node_modules/node-pty/prebuilds/darwin-*/spawn-helper 2>/dev/null || true"
  },
  "dependencies": {
    "@aws-sdk/client-pricing": "^3.1014.0",
    "@hono/node-server": "^1.19.11",
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "@types/bcrypt": "^6.0.0",
    "bcrypt": "^6.0.0",
    "better-auth": "^1.5.5",
    "hono": "^4.12.12",
    "ioredis": "^5.10.0",
    "node-pty": "^1.1.0",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.0.0",
    "prisma": "^7.5.0",
    "resend": "^6.9.4",
    "uuid": "^13.0.0",
    "ws": "^8.18.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/pg": "^8.18.0",
    "@types/ws": "^8.5.14",
    "@vitest/coverage-v8": "^4.1.0",
    "tsx": "^4.19.2",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=10.0.0"
  }
}
